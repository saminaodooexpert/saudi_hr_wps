<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_wps" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.wps</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='work_email']" position="after">
                <field name="x_iqama_id" string="Iqama/ID Number"/>
                <field name="x_bank_iban" string="Bank IBAN (KSA)"/>
            </xpath>
        </field>
    </record>
</odoo>
